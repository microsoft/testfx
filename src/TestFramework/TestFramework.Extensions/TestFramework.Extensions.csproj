<Project>

  <!-- SDK top import -->
  <Import Project="Sdk.props" Sdk="MSBuild.Sdk.Extras" Condition=" '$(OS)' == 'Windows_NT' " />
  <Import Project="Sdk.props" Sdk="Microsoft.NET.Sdk" Condition=" '$(OS)' != 'Windows_NT' " />

  <PropertyGroup>
    <TargetFrameworks Condition=" '$(OS)' == 'Windows_NT' ">netstandard2.0;$(NetFrameworkMinimum);$(SupportedNetFrameworks);$(UwpMinimum);$(ModernUwpMinimum);$(WinUiMinimum)</TargetFrameworks>
    <TargetFrameworks Condition=" '$(OS)' != 'Windows_NT' ">$(SupportedNetFrameworks);netstandard2.0</TargetFrameworks>
  </PropertyGroup>

  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <!--
      This package has a non-standard layout (the Extensions assembly goes to buildTransitive for
      modern TFMs, and there are WinUI/UWP specific assets), so the package contents are produced
      manually through MSBuild items/targets rather than the default SDK build output.
    -->
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <PackageId>MSTest.TestFramework</PackageId>
    <PackageTags>MSTest TestFramework Unittest MSTestV2 Microsoft Test Testing TDD Framework</PackageTags>
    <PackageDescription>
      MSTest is Microsoft supported Test Framework.

      This package includes the libraries for writing tests with MSTest. To ensure discovery and execution of your tests, install the MSTest.TestAdapter package.

      Supported platforms:
      - .NET 4.6.2+
      - .NET 8.0+
      - .NET 8.0 Windows.18362+ (WinUI)
      - UWP 10.0.16299
      - UWP 10.0.17763 with .NET 9+
    </PackageDescription>
    <NoWarn>$(NoWarn);NU5100;NU5128</NoWarn>
  </PropertyGroup>

  <PropertyGroup>
    <RootNamespace>Microsoft.VisualStudio.TestTools.UnitTesting</RootNamespace>
    <AssemblyName>MSTest.TestFramework.Extensions</AssemblyName>
    <DefineConstants>$(DefineConstants);TRACE</DefineConstants>

    <DefineConstants>$(DefineConstants);EXCLUDE_RANGE_INDEX_POLYFILL;EXCLUDE_OS_POLYFILL</DefineConstants>
  </PropertyGroup>

  <!-- WinUI specific properties -->
  <PropertyGroup Condition=" '$(TargetFramework)' == '$(WinUiMinimum)' ">
    <DefineConstants>$(DefineConstants);WIN_UI</DefineConstants>
    <TargetPlatformVersion>10.0.18362.0</TargetPlatformVersion>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <SupportedOSPlatformVersion>10.0.17763.0</SupportedOSPlatformVersion>
    <RuntimeIdentifiers>win-x86;win-x64;win-arm64</RuntimeIdentifiers>
  </PropertyGroup>
  <!-- UWP specific properties -->
  <PropertyGroup Condition=" '$(TargetFramework)' == '$(UwpMinimum)' OR '$(TargetFramework)' == '$(ModernUwpMinimum)' ">
    <DefineConstants>$(DefineConstants);WINDOWS_UWP</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <!-- The core MSTest.TestFramework assembly is bundled into lib (see the packaging target below) and must keep
         flowing transitively for downstream compilation, so it is referenced normally (not PrivateAssets="all").
         NuGet therefore surfaces it as a package dependency on "NotPublishable"; the _RemoveNonPublishableCoreDependency
         target below strips that invalid dependency from the produced package. -->
    <ProjectReference Condition=" '$(TargetFramework)' == '$(UwpMinimum)' " Include="$(RepoRoot)src\TestFramework\TestFramework\TestFramework.csproj" SetTargetFramework="TargetFramework=netstandard2.0" Private="True" />
    <ProjectReference Condition=" '$(TargetFramework)' != '$(UwpMinimum)' " Include="$(RepoRoot)src\TestFramework\TestFramework\TestFramework.csproj" />

    <!-- The only package dependency: MSTest.Analyzers (all assets, including the analyzers, must flow to consumers,
         hence PrivateAssets="none"). The package is produced by MSTest.Analyzers.Package.csproj. -->
    <ProjectReference Include="$(RepoRoot)src\Analyzers\MSTest.Analyzers.Package\MSTest.Analyzers.Package.csproj" PrivateAssets="none" />
  </ItemGroup>

  <ItemGroup>
    <!-- WinUI dependency must not flow to consumers of the package. -->
    <PackageReference Condition=" '$(TargetFramework)' == '$(WinUiMinimum)' " Include="Microsoft.WindowsAppSDK" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="$(RepoRoot)src/Polyfills/**/*.cs" Link="Polyfills\%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

  <ItemGroup Condition=" '$(TargetFramework)' == '$(NetFrameworkMinimum)' ">
    <Reference Include="System.Configuration" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Condition=" '$(TargetFramework)' == '$(UwpMinimum)' OR '$(TargetFramework)' == '$(ModernUwpMinimum)' " Update="Properties\Extension.UWP.rd.xml" />
    <!-- API that is common to all frameworks that we build for. -->
    <AdditionalFiles Include="PublicAPI\PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI\PublicAPI.Unshipped.txt" />
    <!-- Framework specific API -->
    <AdditionalFiles Include="PublicAPI\$(TargetFramework)\PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI\$(TargetFramework)\PublicAPI.Unshipped.txt" />
  </ItemGroup>

  <!--
    Static MSBuild assets (build/ and buildTransitive/ .targets files). These source files always exist,
    so they are added at evaluation time. A single source file is mapped to several package folders where
    needed (e.g. the "others" transitive targets are reused for netstandard2.0, net462 and uap10.0).
    The net462/uap10.0 assets are only relevant on Windows, where those target frameworks are built.
  -->
  <ItemGroup Label="Package build assets">
    <None Include="build\netstandard2.0\MSTest.TestFramework.targets" Pack="true" PackagePath="build\netstandard2.0\" />
    <None Include="build\net8.0\MSTest.TestFramework.targets" Pack="true" PackagePath="build\net8.0\" />
    <None Include="build\net9.0\MSTest.TestFramework.targets" Pack="true" PackagePath="build\net9.0\" />

    <None Include="buildTransitive\others\MSTest.TestFramework.targets" Pack="true" PackagePath="buildTransitive\netstandard2.0\" />
    <None Include="buildTransitive\net8.0AndLater\MSTest.TestFramework.targets" Pack="true" PackagePath="buildTransitive\net8.0\" />
    <None Include="buildTransitive\net8.0AndLater\MSTest.TestFramework.targets" Pack="true" PackagePath="buildTransitive\net9.0\" />
  </ItemGroup>

  <ItemGroup Label="Package build assets (Windows-only TFMs)" Condition=" '$(OS)' == 'Windows_NT' ">
    <None Include="build\net462\MSTest.TestFramework.targets" Pack="true" PackagePath="build\net462\" />
    <None Include="build\uap10.0\MSTest.TestFramework.targets" Pack="true" PackagePath="build\uap10.0\" />

    <None Include="buildTransitive\others\MSTest.TestFramework.targets" Pack="true" PackagePath="buildTransitive\net462\" />
    <None Include="buildTransitive\others\MSTest.TestFramework.targets" Pack="true" PackagePath="buildTransitive\uap10.0\" />
  </ItemGroup>

  <!--
    The core MSTest.TestFramework assembly is produced by a project whose PackageId is "NotPublishable"
    (to avoid a circular/self reference). It is bundled into lib and must keep flowing transitively for the
    compilation of downstream projects (e.g. MSTestAdapter.PlatformServices), so it cannot be marked
    PrivateAssets="all". Because it is referenced directly, NuGet surfaces it as a package dependency, which is
    invalid (there is no "NotPublishable" package). The post-pack target below rewrites the produced package's
    manifest to drop that single dependency, using only built-in MSBuild tasks so it works on all platforms.
  -->
  <UsingTask TaskName="_WriteTextFile" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <Path ParameterType="System.String" Required="true" />
      <Content ParameterType="System.String" Required="true" />
    </ParameterGroup>
    <Task>
      <Code Type="Fragment" Language="cs"><![CDATA[
        System.IO.File.WriteAllText(Path, Content);
      ]]></Code>
    </Task>
  </UsingTask>

  <Target Name="_RemoveNonPublishableCoreDependency" AfterTargets="Pack" Condition=" '$(IsPackable)' == 'true' ">
    <PropertyGroup>
      <_NonPublishableNupkg>$(PackageOutputPath)$(PackageId).$(PackageVersion).nupkg</_NonPublishableNupkg>
      <_NonPublishableExtractDir>$(BaseIntermediateOutputPath)nupkgfix\</_NonPublishableExtractDir>
    </PropertyGroup>

    <RemoveDir Directories="$(_NonPublishableExtractDir)" />
    <Unzip SourceFiles="$(_NonPublishableNupkg)" DestinationFolder="$(_NonPublishableExtractDir)" />

    <PropertyGroup>
      <_NonPublishableNuspecPath>$(_NonPublishableExtractDir)$(PackageId).nuspec</_NonPublishableNuspecPath>
      <_NonPublishableNuspecContent>$([System.IO.File]::ReadAllText($(_NonPublishableNuspecPath)))</_NonPublishableNuspecContent>
      <_NonPublishableNuspecFixed>$([System.Text.RegularExpressions.Regex]::Replace($(_NonPublishableNuspecContent), '[ \t]*&lt;dependency id="NotPublishable"[^&gt;]*/&gt;[ \t]*\r?\n', ''))</_NonPublishableNuspecFixed>
    </PropertyGroup>

    <_WriteTextFile Path="$(_NonPublishableNuspecPath)" Content="$(_NonPublishableNuspecFixed)" />

    <Delete Files="$(_NonPublishableNupkg)" />
    <ZipDirectory SourceDirectory="$(_NonPublishableExtractDir)" DestinationFile="$(_NonPublishableNupkg)" />
    <RemoveDir Directories="$(_NonPublishableExtractDir)" />
    <Message Importance="high" Text="Removed the 'NotPublishable' project dependency from $(_NonPublishableNupkg)." />
  </Target>

  <!--
    Per-TFM build outputs (assemblies, xml docs and localized satellites). Collected at pack time so that
    the outputs (including the bundled core MSTest.TestFramework assembly copied from the project reference)
    exist. Placement differs per TFM:
      - core MSTest.TestFramework.dll/.xml/resources -> lib/<tfm> (except the WinUI/UWP only passes)
      - MSTest.TestFramework.Extensions.dll/.xml     -> lib/<tfm> for netstandard2.0/net462/uap10.0
                                                     -> buildTransitive/<tfm> for net8.0/net9.0
                                                     -> buildTransitive/net8.0/winui (WinUI pass)
                                                     -> buildTransitive/net9.0/uwp   (ModernUwp pass)
  -->
  <PropertyGroup>
    <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);_AddTestFrameworkPackageFiles</TargetsForTfmSpecificContentInPackage>
  </PropertyGroup>

  <Target Name="_AddTestFrameworkPackageFiles" DependsOnTargets="BuildOnlySettings;ResolveReferences">
    <PropertyGroup>
      <!-- Map the build TFM to the package folder name. -->
      <_PackageTfm Condition=" '$(TargetFramework)' == '$(UwpMinimum)' ">uap10.0</_PackageTfm>
      <_PackageTfm Condition=" '$(_PackageTfm)' == '' ">$(TargetFramework)</_PackageTfm>

      <!-- Destination of the Extensions assembly and whether the core assembly is bundled in lib for this TFM. -->
      <_ExtensionsPackagePath Condition=" '$(TargetFramework)' == 'netstandard2.0' OR '$(TargetFramework)' == '$(NetFrameworkMinimum)' OR '$(TargetFramework)' == '$(UwpMinimum)' ">lib\$(_PackageTfm)\</_ExtensionsPackagePath>
      <_ExtensionsPackagePath Condition=" '$(TargetFramework)' == 'net8.0' OR '$(TargetFramework)' == 'net9.0' ">buildTransitive\$(TargetFramework)\</_ExtensionsPackagePath>
      <_ExtensionsPackagePath Condition=" '$(TargetFramework)' == '$(WinUiMinimum)' ">buildTransitive\net8.0\winui\</_ExtensionsPackagePath>
      <_ExtensionsPackagePath Condition=" '$(TargetFramework)' == '$(ModernUwpMinimum)' ">buildTransitive\net9.0\uwp\</_ExtensionsPackagePath>

      <!-- The core assembly is bundled in lib for every TFM except the WinUI/UWP-only passes. -->
      <_BundleCoreAssembly>true</_BundleCoreAssembly>
      <_BundleCoreAssembly Condition=" '$(TargetFramework)' == '$(WinUiMinimum)' OR '$(TargetFramework)' == '$(ModernUwpMinimum)' ">false</_BundleCoreAssembly>
    </PropertyGroup>

    <ItemGroup>
      <!-- Extensions assembly + xml doc. -->
      <TfmSpecificPackageFile Include="$(TargetDir)MSTest.TestFramework.Extensions.dll" PackagePath="$(_ExtensionsPackagePath)" />
      <TfmSpecificPackageFile Include="$(TargetDir)MSTest.TestFramework.Extensions.xml" PackagePath="$(_ExtensionsPackagePath)" />

      <!-- Core assembly + xml doc + localized satellites (only the core resources are shipped). -->
      <_CoreResourceFile Include="$(TargetDir)**\MSTest.TestFramework.resources.dll" />
      <TfmSpecificPackageFile Condition=" '$(_BundleCoreAssembly)' == 'true' " Include="$(TargetDir)MSTest.TestFramework.dll" PackagePath="lib\$(_PackageTfm)\" />
      <TfmSpecificPackageFile Condition=" '$(_BundleCoreAssembly)' == 'true' " Include="$(TargetDir)MSTest.TestFramework.xml" PackagePath="lib\$(_PackageTfm)\" />
      <TfmSpecificPackageFile Condition=" '$(_BundleCoreAssembly)' == 'true' " Include="@(_CoreResourceFile)" PackagePath="lib\$(_PackageTfm)\" />
    </ItemGroup>
  </Target>

  <ItemGroup>
    <Using Include="Polyfills" />
    <Using Include="$(RootNamespace).Resources" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="MSTestAdapter.PlatformServices" Key="$(VsPublicKey)" />
    <InternalsVisibleTo Include="MSTestAdapter.PlatformServices.UnitTests" Key="$(VsPublicKey)" />
  </ItemGroup>

  <!-- SDK bottom import -->
  <Import Project="Sdk.targets" Sdk="MSBuild.Sdk.Extras" Condition=" '$(OS)' == 'Windows_NT' " />
  <Import Project="Sdk.targets" Sdk="Microsoft.NET.Sdk" Condition=" '$(OS)' != 'Windows_NT' " />

</Project>
