        <dependency id="MSTest.TestFramework" version="$Version$" />
      </group>
      <group targetFramework="net9.0-windows7.0">
        <dependency id="MSTest.TestFramework" version="$Version$" />
      </group>
    </dependencies>
    <frameworkReferences>
      <group targetFramework="net8.0-windows7.0">
        <frameworkReference name="Microsoft.WindowsDesktop.App.WPF" />
      </group>
      <group targetFramework="net9.0-windows7.0">
        <frameworkReference name="Microsoft.WindowsDesktop.App.WPF" />
      </group>
    </frameworkReferences>
  </metadata>
  <files>
    $CommonFileElements$

    <!-- net8.0-windows -->
