<Project Sdk="MSTest.Sdk">

  <!--
    NativeAOT sample for MSTest. Uses MSTest.Sdk (version is set in samples/public/global.json), which
    detects PublishAot=true and wires the matching set of MSTest source-generation + runner packages.

    Until the new MSTest.SourceGeneration version corresponding to https://github.com/microsoft/testfx/pull/8586
    is published, this sample intentionally relies on MSTest.Sdk's published version rather than
    referencing MSTest.SourceGeneration directly via $(MSTestAOTVersion).
  -->
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <PublishAot>true</PublishAot>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\ClassLibrary1\ClassLibrary1.csproj" />
  </ItemGroup>

</Project>
