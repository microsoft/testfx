<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!--
      By default we restore from our validated dotnet-public mirror only (for security reasons).
      nuget.org is additionally required because the Native AOT sample references the pre-release
      MSTest.SourceGeneration package, and these fast-moving pre-release packages are not always
      promoted to the dotnet-public mirror. The packageSourceMapping below preserves the security
      posture: every package still resolves from the validated mirror, except MSTest.SourceGeneration
      which is restored from nuget.org.
     -->
    <add key="dotnet-public" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-public/nuget/v3/index.json" />
    <add key="nuget" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="dotnet-public">
      <package pattern="*" />
    </packageSource>
    <packageSource key="nuget">
      <package pattern="MSTest.SourceGeneration" />
    </packageSource>
  </packageSourceMapping>
</configuration>
