<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net9.0;net462</TargetFrameworks>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <AssemblyName>Microsoft.Testing.Extensions.VideoRecorder</AssemblyName>
    <RootNamespace>Microsoft.Testing.Extensions.VideoRecorder</RootNamespace>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <!--
      Sample project: relax a few code-style analyzers that either are pure style preferences
      or conflict with multi-targeting net462 (which lacks System.Threading.Lock and the
      FlushAsync(CancellationToken) overload).
    -->
    <NoWarn>$(NoWarn);NETSDK1023;SA0001;EnableGenerateDocumentationFile;IDE0028;IDE0032;IDE0330;CA2016</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="$(RepoRoot)src\Platform\Microsoft.Testing.Platform\Microsoft.Testing.Platform.csproj" />
  </ItemGroup>

  <!-- Localized, strongly-typed resources (generated by XliffTasks from the .resx). -->
  <ItemGroup>
    <EmbeddedResource Update="Resources\VideoRecorderResources.resx">
      <GenerateSource>true</GenerateSource>
      <Namespace>Microsoft.Testing.Extensions.VideoRecorder.Resources</Namespace>
      <ClassName>Microsoft.Testing.Extensions.VideoRecorder.Resources.VideoRecorderResources</ClassName>
    </EmbeddedResource>
  </ItemGroup>

</Project>
