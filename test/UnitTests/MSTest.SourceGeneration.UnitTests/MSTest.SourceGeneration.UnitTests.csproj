<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0</TargetFrameworks>
    <RootNamespace>Microsoft.Testing.Framework.SourceGeneration.UnitTests</RootNamespace>
    <NoWarn>$(NoWarn);NU1701</NoWarn>
    <EnableMSTestRunner>true</EnableMSTestRunner>
    <OutputType>Exe</OutputType>
  </PropertyGroup>

  <!-- Exclude shared polyfills: MSTest.SourceGeneration (netstandard2.0) exposes internal polyfill types
       via InternalsVisibleTo, which conflict with System.Runtime types on net8.0. -->
  <ItemGroup>
    <Compile Remove="$(MSBuildThisFileDirectory)..\..\..\eng\Polyfills.cs" />
    <Compile Remove="$(RepoRoot)eng\Polyfills.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" PrivateAssets="all" VersionOverride="$(MicrosoftCodeAnalysisVersionForSourceGen)" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.CodeFix.Testing" PrivateAssets="all" />
    <PackageReference Include="AwesomeAssertions" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="$(RepoRoot)\test\Utilities\Microsoft.Testing.TestInfrastructure\RootFinder.cs" Link="RootFinder.cs" />
  </ItemGroup>
  
  <ItemGroup>
    <None Update="*.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="$(RepoRoot)src\Adapter\MSTest.Engine\MSTest.Engine.csproj" />
    <ProjectReference Include="$(RepoRoot)src\Analyzers\MSTest.SourceGeneration\MSTest.SourceGeneration.csproj">
      <OutputItemType>Analyzer</OutputItemType>
      <ReferenceOutputAssembly>true</ReferenceOutputAssembly>
      <Aliases>SourceGen</Aliases>
    </ProjectReference>
  </ItemGroup>

</Project>
